# Application
PROJECT_NAME=MyApp
FRONTEND_URL=http://localhost:3000
SECRET_KEY=replace-with-a-long-random-value
JWT_SIGNING_KEY=replace-with-an-independent-long-random-value
JWT_AUDIENCE=django-ninja-api
JWT_ISSUER=django-ninja-api
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=

# PostgreSQL
POSTGRES_DB=django_db
POSTGRES_USER=django_user
POSTGRES_PASSWORD=replace-with-a-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Redis / Celery
REDIS_URL=redis://redis:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_TASK_TIME_LIMIT=1800

# S3-compatible private media storage (Cloudflare R2 works)
R2_ACCESS_KEY_ID=replace-with-storage-access-key
R2_SECRET_ACCESS_KEY=replace-with-storage-secret-key
R2_ENDPOINT_URL=https://account-id.r2.cloudflarestorage.com
R2_REGION_NAME=auto
R2_PRIVATE_BUCKET_NAME=private-media

# Optional public storage, used by public avatar support
R2_PUBLIC_BUCKET_NAME=public-media
IMAGE_PUBLIC_BASE_URL=https://media.example.com

# Transactional email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-smtp-user
EMAIL_HOST_PASSWORD=replace-with-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=MyApp <noreply@example.com>

# Production proxy/security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Production Compose interpolation (put these in the shell or a separate
# Compose environment file, not in the application env file)
APP_IMAGE=ghcr.io/example/myapp:replace-with-immutable-tag
DOMAIN=api.example.com
REDIS_PASSWORD=replace-with-a-redis-password
