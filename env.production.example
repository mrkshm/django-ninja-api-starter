PROJECT_NAME=MyApp
FRONTEND_URL=https://app.example.com
SECRET_KEY=replace-with-at-least-50-random-characters
JWT_SIGNING_KEY=replace-with-a-different-random-signing-key
JWT_AUDIENCE=django-ninja-api
JWT_ISSUER=django-ninja-api
DJANGO_ALLOWED_HOSTS=api.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://app.example.com

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-a-database-password

R2_ACCESS_KEY_ID=replace-with-storage-access-key
R2_SECRET_ACCESS_KEY=replace-with-storage-secret-key
R2_ENDPOINT_URL=https://account-id.r2.cloudflarestorage.com
R2_REGION_NAME=auto
R2_PRIVATE_BUCKET_NAME=private-media
R2_PUBLIC_BUCKET_NAME=public-media
IMAGE_PUBLIC_BASE_URL=https://media.example.com

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-smtp-user
EMAIL_HOST_PASSWORD=replace-with-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=MyApp <noreply@example.com>

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
